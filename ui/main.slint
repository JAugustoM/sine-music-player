import { Button, HorizontalBox, VerticalBox, Slider } from "std-widgets.slint";
import { Icons } from "assets/icons.slint";
import { DraculaTheme } from "theme/dracula.slint";

export component AppWindow inherits Window {
    title: "Sine Music Player";

    preferred-width: 1920px;
    preferred-height: 1080px;
    min-width: 800px;
    min-height: 600px;

    background: DraculaTheme.background;

    in property <string> music-title: "";
    in property <string> music-album: "";
    in property <string> music-album-artist: "";

    in property <string> current-state: "Paused";
    in property <string> current-timestamp: "00:00";
    in property <string> final-timestamp: "00:00";
    in-out property <float> music-progress: 0;
    in property <float> music-duration: 0;
    in property <string> repeat-mode: "Off";
    in property <image> cover-art;

    callback toggle-clicked();
    callback previous-button();
    callback next-button();
    callback toggle-repeat();
    callback file-picker();
    callback set-timestamp(float);

    VerticalLayout {
        Rectangle {
            // Main area automatically fills remaining vertical space
        }

        Rectangle {
            height: 96px;
            background: DraculaTheme.surface;

            HorizontalBox {
                alignment: space-between;
                padding: 0px;
                spacing: 24px;

                HorizontalLayout {
                    horizontal-stretch: 1;
                    max-width: 300px;
                    min-width: 200px;
                    spacing: 16px;
                    alignment: start;

                    Rectangle {
                        width: self.height;
                        height: parent.height;
                        background: DraculaTheme.muted;
                        clip: true;

                        Image {
                            width: 100%;
                            height: 100%;
                            source: root.cover-art;
                            image-fit: cover;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        spacing: 4px;

                        Text {
                            text: root.music-title;
                            color: DraculaTheme.foreground;
                            font-size: 16px;
                            font-weight: 600;
                            overflow: elide;
                        }

                        Text {
                            text: root.music-album-artist;
                            color: DraculaTheme.purple;
                            font-size: 13px;
                            overflow: elide;
                        }
                    }
                }

                VerticalLayout {
                    horizontal-stretch: 2;
                    alignment: center;
                    spacing: 8px;

                    HorizontalLayout {
                        alignment: center;
                        spacing: 16px;

                        Button {
                            icon: Icons.skip-previous;
                            clicked => {
                                root.previous-button()
                            }
                        }

                        Button {
                            icon: root.current-state == "Playing" ? Icons.pause : Icons.play;
                            clicked => {
                                root.toggle-clicked()
                            }
                        }

                        Button {
                            icon: Icons.skip-next;
                            clicked => {
                                root.next-button()
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 12px;
                        alignment: center;

                        Text {
                            text: root.current-timestamp;
                            color: DraculaTheme.foreground;
                            font-size: 12px;
                            vertical-alignment: center;
                        }

                        Slider {
                            minimum: 0;
                            maximum: root.music-duration;
                            min-width: 316px;
                            value <=> root.music-progress;

                            changed(value) => {
                                root.set-timestamp(value);
                            }
                            released => {
                                self.clear-focus();
                            }
                        }

                        Text {
                            text: root.final-timestamp;
                            color: DraculaTheme.foreground;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                }

                HorizontalLayout {
                    horizontal-stretch: 1;
                    max-width: 300px;
                    min-width: 200px;
                    alignment: end;
                    spacing: 12px;

                    Button {
                        icon: Icons.files;
                        clicked => {
                            root.file-picker()
                        }
                    }

                    Button {
                        icon: root.repeat-mode == "Track" ? Icons.repeat_one : root.repeat-mode == "Playlist" ? Icons.repeat_on : Icons.repeat_off;
                        clicked => {
                            root.toggle-repeat()
                        }
                    }
                }
            }
        }
    }
}
