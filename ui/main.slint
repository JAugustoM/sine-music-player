import { Button, VerticalBox, HorizontalBox, ProgressIndicator } from "std-widgets.slint";
import { Icons } from "assets/icons/icons.slint";

export component AppWindow inherits Window {
    title: "Sine Music Player";

    in property <string> current-state: "Ready to play";
    in property <string> current-timestamp: "00:00";
    in property <string> music-duration: "00:00";
    in property <float> music-progress: 0;

    callback toggle-clicked <=> toggle-button.clicked;
    callback clear-clicked <=> clear-button.clicked;
    callback file-picker <=> file-picker.clicked;

    VerticalLayout {
        alignment: center;

        Text {
            text: root.current-state;
            font-size: 24px;
            horizontal-alignment: center;
        }

        Text {
            text: root.current-timestamp + "/" + root.music-duration;
            font-size: 16px;
            horizontal-alignment: center;
        }

        VerticalBox {
            max-width: 360px;
            ProgressIndicator {
                progress: music-progress;
            }
        }

        HorizontalBox {
            alignment: center;
            toggle-button := Button {
                icon: root.current-state == "Playing" ? Icons.pause : Icons.play;
            }
            clear-button := Button {
                icon: Icons.clear;
            }
            file-picker := Button {
                icon: Icons.files;
            }
        }
    }
}
