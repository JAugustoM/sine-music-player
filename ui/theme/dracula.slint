export global DraculaTheme {
    // --- Base Colors ---
    
    // Default background color for windows and main views
    out property <color> background: #282A36;

    // Lighter background for cards, control bars, and current line highlights
    out property <color> surface: #44475A;

    // Default text and icon color
    out property <color> foreground: #F8F8F2;

    // Muted text, borders, or disabled states
    out property <color> muted: #6272A4;

    // --- Accent Colors ---
    
    // Primary brand color (Great for active states, play buttons, focused sliders)
    out property <color> purple: #BD93F9;

    // Secondary accent
    out property <color> pink: #FF79C6;

    // Tertiary / Info
    out property <color> cyan: #8BE9FD;

    // Success / Playback active
    out property <color> green: #50FA7B;

    // Warning
    out property <color> yellow: #F1FA8C;

    // Secondary Warning / Accent
    out property <color> orange: #FFB86C;

    // Error / Destructive actions (like clearing the queue)
    out property <color> red: #FF5555;
}
